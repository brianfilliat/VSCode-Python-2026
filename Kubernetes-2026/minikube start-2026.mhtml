  name: foo-service
spec:
  selector:
    app: foo
  ports:
    - port: <span class=3D"token number">8080</span>
---
kind: Pod
apiVersion: v1
metadata:
  name: bar-app
  labels:
    app: bar
spec:
  containers:
    - name: bar-app
      image: <span class=3D"token string">'kicbase/echo-server:1.0'</span>
---
kind: Service
apiVersion: v1
metadata:
  name: bar-service
spec:
  selector:
    app: bar
  ports:
    - port: <span class=3D"token number">8080</span>
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: example-ingress
spec:
  rules:
    - http:
        paths:
          - pathType: Prefix
            path: /foo
            backend:
              service:
                name: foo-service
                port:
                  number: <span class=3D"token number">8080</span>
          - pathType: Prefix
            path: /bar
            backend:
              service:
                name: bar-service
                port:
                  number: <span class=3D"token number">8080</span>
---
</code></pre><div class=3D"toolbar"><div class=3D"toolbar-item"><button cla=
ss=3D"copy-to-clipboard-button" type=3D"button" data-copy-state=3D"copy"><s=
pan>Copy</span></button></div></div></div></div><p>Apply the contents</p>
<div class=3D"highlight"><div class=3D"code-toolbar"><pre tabindex=3D"0" st=
yle=3D"background-color:#fff;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webk=
it-text-size-adjust:none;" class=3D"language-shell"><code class=3D"language=
