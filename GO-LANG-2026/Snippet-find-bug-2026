func CleanupCompletedJobs(ctx context.Context, clientset *kubernetes.Clientset, ns string) error {
	// 1. Get the list of jobs
	jobs, err := clientset.BatchV1().Jobs(ns).List(ctx, metav1.ListOptions{})
	if err != nil {
		return err
	}

	for _, job := range jobs.Items {
		// 2. Check if the job succeeded
		if job.Status.Succeeded > 0 {
			fmt.Printf("Deleting successful job: %s\n", job.Name)

			// 3. Delete the job
			err := clientset.BatchV1().Jobs(ns).Delete(ctx, job.Name, metav1.DeleteOptions{})
			if err != nil {
				fmt.Printf("Failed to delete %s: %v\n", job.Name, err)
			}
		}
	}
	return nil
}





