package main

import (
	"context"
	"flag"
	"fmt"
	"os"
	"path/filepath"
	"time"

	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
	"k8s.io/client-go/kubernetes"
	"k8s.io/client-go/tools/clientcmd"
	"k8s.io/client-go/util/homedir"
)

func main() {
	// 1. Setup Kubeconfig (same as starter template)
	var kubeconfig *string
	if home := homedir.HomeDir(); home != "" {
		kubeconfig = flag.String("kubeconfig", filepath.Join(home, ".kube", "config"), "path to kubeconfig")
	} else {
		kubeconfig = flag.String("kubeconfig", "", "path to kubeconfig")
	}
	flag.Parse()

	config, _ := clientcmd.BuildConfigFromFlags("", *kubeconfig)
	clientset, _ := kubernetes.NewForConfig(config)

	// 2. Define our "Stale" threshold (e.g., 24 hours)
	threshold := 24 * time.Hour
	namespace := "default"
	ctx := context.Background()

	fmt.Printf("Searching for pods in '%s' older than %v...\n", namespace, threshold)

	// 3. List all Pods in the namespace
	pods, err := clientset.CoreV1().Pods(namespace).List(ctx, metav1.ListOptions{})
	if err != nil {
		fmt.Printf("Error: %v\n", err)
		os.Exit(1)
	}

	for _, pod := range pods.Items {
		// 4. Logic: If Pod is NOT Running AND older than threshold
		age := time.Since(pod.CreationTimestamp.Time)

		if pod.Status.Phase != "Running" && age > threshold {
			fmt.Printf("Found Stale Pod: %s (Status: %s, Age: %v)\n", pod.Name, pod.Status.Phase, age)

			// 5. Delete the Pod
			err := clientset.CoreV1().Pods(namespace).Delete(ctx, pod.Name, metav1.DeleteOptions{})
			if err != nil {
				fmt.Printf("Failed to delete %s: %v\n", pod.Name, err)
			} else {
				fmt.Printf("Successfully deleted %s\n", pod.Name)
			}
		}
	}
}

/*
Key Technical Details to Mention in an Interview

1) metav1.Time vs time.Time
In Kubernetes, timestamps are represented as metav1.Time.
To use Go's time functions such as time.Since(), access the underlying
time.Time using the .Time field.
Example: age := time.Since(pod.CreationTimestamp.Time)

2) Pod Phases nuance
This example checks pod.Status.Phase against "Running".
In real production scenarios, consider explicitly targeting phases like
Pending, Failed, or Succeeded. This helps avoid deleting pods that may be
in CrashLoopBackOff while still technically reporting the Running phase
at the exact check moment.

3) Optimize with Field Selectors
For large clusters (for example, a large RKE environment), listing all pods
and filtering in client code is inefficient.
Use a field selector so the API server performs filtering:

listOptions := metav1.ListOptions{
	FieldSelector: "status.phase!=Running",
}

This reduces network traffic and client-side memory usage.
*/
